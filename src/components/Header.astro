---
// src/components/Header.astro
import { Icon } from "astro-icon/components";
---

<header
  x-data
  :class="{ 'bg-white/80 backdrop-blur-md border-b border-black/10 shadow-sm': $store.ui.scrolled, 'bg-transparent': !$store.ui.scrolled }"
  class="fixed top-0 left-0 right-0 z-[100] w-full transition-all duration-300 ease-in-out"
>
  <div
    class="max-w-7xl mx-auto h-20 flex items-center justify-between px-6 lg:px-8"
  >
    <a
      href="/"
      class="text-2xl font-bold tracking-tighter text-black flex-shrink-0"
    >
      BRAND
    </a>

    <nav class="hidden md:flex items-center gap-10">
      <a
        href="#about"
        class="text-sm font-medium hover:text-gray-500 transition-colors"
        >About</a
      >
      <a
        href="#features"
        class="text-sm font-medium hover:text-gray-500 transition-colors"
        >Features</a
      >
      <a
        href="#team"
        class="text-sm font-medium hover:text-gray-500 transition-colors"
        >Team</a
      >
      <a
        href="#pricing"
        class="text-sm font-medium hover:text-gray-500 transition-colors"
        >Pricing</a
      >
      <a
        href="#contact"
        class="bg-black text-white px-6 py-2 rounded-full text-sm font-bold hover:bg-gray-800 transition-all"
      >
        Contact Us
      </a>
    </nav>

    <button @click="$store.ui.toggleMenu()" class="md:hidden p-2">
      <Icon name="lucide:menu" class="w-6 h-6" />
    </button>
  </div>
</header>
