---
import { Icon } from "astro-icon/components";

const team = [
  {
    name: "Matt Richardson",
    role: "Founder & Lead Dev",
    image: "https://i.pravatar.cc/300?u=matt",
    bio: "Ex-FAANG engineer obsessed with load times and clean code.",
    links: { twitter: "#", linkedin: "#", github: "#" },
  },
  {
    name: "Sarah Chenet",
    role: "UI/UX Designer",
    image: "https://i.pravatar.cc/300?u=sarah",
    bio: "Creating digital experiences that feel as good as they look.",
    links: { twitter: "#", linkedin: "#", instagram: "#" },
  },
  {
    name: "Islay McTavish",
    role: "Growth Marketer",
    image: "https://i.pravatar.cc/300?u=islay",
    bio: "Data-driven strategist specialized in scaling SaaS products.",
    links: { twitter: "#", linkedin: "#" },
  },
];
---

<section id="team" class="py-24 bg-white">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl mb-16">
      <h3
        class="text-sm font-bold uppercase tracking-widest text-brand-accent mb-4"
      >
        The Minds Behind
      </h3>
      <h2 class="text-4xl lg:text-5xl font-bold tracking-tight text-black">
        Built by people who care about the web.
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-12">
      {
        team.map((member) => (
          <div class="group">
            <div class="relative mb-6 overflow-hidden rounded-[2.5rem] bg-gray-100 aspect-square border border-black/5">
              <img
                src={member.image}
                alt={member.name}
                class="w-full h-full object-cover grayscale group-hover:grayscale-0 transition-all duration-500 group-hover:scale-110"
              />

              <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center gap-4">
                {Object.entries(member.links).map(([platform, url]) => (
                  <a
                    href={url}
                    class="bg-white p-3 rounded-xl text-black hover:bg-brand-accent hover:text-white transition-all transform translate-y-4 group-hover:translate-y-0 duration-500"
                  >
                    <Icon name={`lucide:${platform}`} class="w-5 h-5" />
                  </a>
                ))}
              </div>
            </div>

            <div>
              <h4 class="text-xl font-bold mb-1">{member.name}</h4>
              <p class="text-brand-accent text-sm font-semibold mb-3 uppercase tracking-wider">
                {member.role}
              </p>
              <p class="text-gray-600 text-sm leading-relaxed max-w-xs">
                {member.bio}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
