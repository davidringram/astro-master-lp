---
import { Image } from "astro:assets";
// import heroImage from '../assets/hero-visual.png';
---

<section class="relative pt-32 pb-20 lg:pt-48 lg:pb-32 overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="flex flex-col lg:flex-row items-center gap-16">
      <div class="w-full lg:w-1/2 space-y-8">
        <h1 class="text-5xl lg:text-7xl font-bold tracking-tight leading-tight">
          Build faster. <br />
          <span class="text-brand-accent">Scale harder.</span>
        </h1>
        <p class="text-xl text-gray-600 max-w-lg">
          The master template for high-performance landing pages. Built with
          Astro 5, Tailwind 4, and Alpine.js.
        </p>

        <div
          x-data="{ 
    email: '', 
    sent: false, 
    loading: false,

    async submitForm(e) {
        this.loading = true;
        const form = e.target;
        const formData = new FormData(form);

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: { 'Accept': 'application/json' }
            });

            if (response.ok) {
                this.sent = true;
                this.email = '';
                $store.ui.toast.display('Welcome to the inner circle!');
                if (window.posthog) {
                    posthog.capture('form_submitted', { form_name: 'hero_waitlist' });
                }
            } else {
                $store.ui.toast.display('Server error. Try again.');
            }
        } catch (err) {
            $store.ui.toast.display('Network error. Check your connection.');
        } finally {
            this.loading = false;
        }
    }
  }"
        >
          <form
            action="https://formspree.io/f/xjgejedo"
            method="POST"
            @submit.prevent="submitForm($event)"
            class="flex flex-col sm:flex-row gap-3"
          >
            <input
              type="email"
              name="email"
              x-model="email"
              required
              placeholder="Enter your email"
              class="flex-1 rounded-full border border-black/10 px-6 py-3 focus:border-black outline-none transition-all"
            />
            <button
              type="submit"
              class="bg-black text-white px-8 py-3 rounded-full font-bold hover:bg-gray-800 transition-all disabled:opacity-50"
              :class="loading ? 'cursor-wait' : ''"
              :disabled="loading"
            >
              <span x-show="!loading">Join Waitlist</span>
              <span x-show="loading" class="animate-pulse">Sending...</span>
            </button>
          </form>
        </div>
      </div>
      <div class="w-full lg:w-1/2 relative">
        <div
          class="aspect-square bg-gray-100 rounded-3xl border border-black/5 flex items-center justify-center overflow-hidden"
        >
          <span class="text-gray-400 font-mono italic">Visual Placeholder</span>
        </div>

        <div
          class="absolute -bottom-6 -right-6 w-32 h-32 bg-brand-accent/10 rounded-full blur-3xl"
        >
        </div>
      </div>
    </div>
  </div>
</section>
