---
const tiers = [
  {
    name: "Starter",
    price: "0",
    description: "Perfect for side projects and hobbyists.",
    features: [
      "3 Projects",
      "Basic Analytics",
      "Community Support",
      "Astro 5 Ready",
    ],
    buttonText: "Get Started",
    popular: false,
  },
  {
    name: "Pro",
    price: "49",
    description: "Everything you need to scale your business.",
    features: [
      "Unlimited Projects",
      "Advanced SEO",
      "Priority Support",
      "Custom Domains",
      "Team Collaboration",
    ],
    buttonText: "Start Free Trial",
    popular: true,
  },
  {
    name: "Enterprise",
    price: "99",
    description: "Advanced features for large scale apps.",
    features: [
      "Custom Branding",
      "API Access",
      "Dedicated Manager",
      "White-labeling",
      "24/7 Phone Support",
    ],
    buttonText: "Contact Sales",
    popular: false,
  },
];
---

<section id="pricing" class="py-24 bg-white overflow-hidden">
  <div class="container mx-auto px-6">
    <div class="text-center max-w-2xl mx-auto mb-20">
      <h2 class="text-4xl lg:text-5xl font-bold tracking-tight mb-4">
        Plans for every stage
      </h2>
      <p class="text-gray-600 text-lg">
        Start for free and scale as you grow. No hidden fees.
      </p>
    </div>

    <div
      class="grid md:grid-cols-3 gap-8 lg:gap-12 items-center max-w-7xl mx-auto"
    >
      {
        tiers.map((tier) => (
          <div
            class={`relative group rounded-[2.5rem] transition-all duration-500 ease-out flex flex-col
          ${
            tier.popular
              ? "border-2 border-brand-accent bg-white shadow-2xl py-16 px-10 z-10 scale-105"
              : "border border-black/5 bg-white py-12 px-8 z-0"
          }
          hover:scale-[1.08] hover:z-50 hover:shadow-[0_30px_60px_rgba(0,0,0,0.12)] hover:-translate-y-4`}
          >
            {tier.popular && (
              <div class="absolute -top-5 left-1/2 -translate-x-1/2 bg-brand-accent text-white text-[10px] font-black uppercase tracking-[0.2em] px-5 py-1.5 rounded-full shadow-lg">
                Most Popular
              </div>
            )}

            <div class="mb-8">
              <h3
                class={`text-xl font-bold mb-2 ${tier.popular ? "text-brand-accent" : "text-black"}`}
              >
                {tier.name}
              </h3>
              <p class="text-sm text-gray-500 leading-relaxed">
                {tier.description}
              </p>
            </div>

            <div class="flex items-baseline gap-1 mb-8">
              <span class="text-5xl font-bold tracking-tight">
                ${tier.price}
              </span>
              <span class="text-gray-400 font-medium">/mo</span>
            </div>

            <ul class="space-y-4 mb-10 flex-1">
              {tier.features.map((feature) => (
                <li class="flex items-start gap-3 text-sm text-gray-600">
                  <svg
                    class={`w-5 h-5 mt-0.5 flex-shrink-0 ${tier.popular ? "text-brand-accent" : "text-black"}`}
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2.5"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                  {feature}
                </li>
              ))}
            </ul>

            <button
              class={`w-full py-4 rounded-2xl font-bold transition-all duration-300
            ${
              tier.popular
                ? "bg-brand-accent text-white hover:bg-brand-accent/90 shadow-md shadow-brand-accent/20"
                : "bg-black text-white hover:bg-gray-800"
            }`}
            >
              {tier.buttonText}
            </button>
          </div>
        ))
      }
    </div>
  </div>
</section>
